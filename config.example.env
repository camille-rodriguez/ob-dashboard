# Orangebox Dashboard – environment variable configuration
# Copy this file to .env and fill in the values.
# The application reads these variables at startup.

# ── Orangebox host ─────────────────────────────────────────────────────────────
# IP address or hostname of the orangebox.
# Used to determine whether the box is powered on (ICMP ping).
OB_HOST=10.0.0.1

# ── MAAS ───────────────────────────────────────────────────────────────────────
# Base URL of the MAAS server (no trailing slash).
# Example: http://10.0.0.1:5240/MAAS
MAAS_URL=http://10.0.0.1:5240/MAAS

# MAAS API key in the format:  <consumer_key>:<token_key>:<token_secret>
# Obtain it from the MAAS UI → your account → API keys.
MAAS_API_KEY=consumer_key:token_key:token_secret

# ── Flask ──────────────────────────────────────────────────────────────────────
# Port the Flask development server listens on (default: 5000).
PORT=5000

# Set to "1" to enable Flask debug mode (never use in production).
FLASK_DEBUG=0
